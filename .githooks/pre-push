#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
validator="$repo_root/scripts/validate-remediation-commit-msg.sh"

zero="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_ref:-}" ]] && continue

  if [[ "$local_sha" == "$zero" ]]; then
    # Deletion push.
    continue
  fi

  if [[ "$remote_sha" == "$zero" ]]; then
    range="$local_sha"
  else
    range="$remote_sha..$local_sha"
  fi

  for commit in $(git rev-list "$range"); do
    tmp_msg="/tmp/ecomcine_commit_msg_${commit}.txt"
    git log --format=%B -n 1 "$commit" > "$tmp_msg"
    if ! "$validator" "$tmp_msg"; then
      echo "ERROR: remediation policy validation failed for commit $commit" >&2
      echo "Ref: $local_ref -> $remote_ref" >&2
      exit 1
    fi
  done
done

exit 0
