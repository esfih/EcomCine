# EcomCine — Local Dev Environment
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

COMPOSE_PROJECT_NAME=ecomcine_dev

# WordPress Docker image — targets live site version (WP 6.9.x, PHP 8.2)
# Use wordpress:6.5-php8.1-apache to test against minimum declared WP support.
WP_IMAGE=wordpress:php8.2-apache

# Database
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=wp_pass_dev

# Ports — 8180/8181 reserved for this project
# Run: docker ps --format 'table {{.Ports}}' to check for conflicts
WP_PORT=8180
PMA_PORT=8181

# Plugin/theme slugs (used by check-local-wp.sh health checks)
# Primary custom plugin slug — used to verify activation
PLUGIN_SLUG=tm-media-player
# EcomCine does not use a control-plane billing plugin (no CP_PLUGIN_SLUG)
CP_PLUGIN_SLUG=
