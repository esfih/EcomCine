# ── Secrets & credentials ─────────────────────────────────────────────────────
.env

# ── Third-party dependency plugins (gitignored — store locally in deps/) ──────
deps/

# ── Database exports — never commit live or unscrubbed dumps ──────────────────
db/*.sql
# Allowed scrubbed fixtures used for reproducible local bootstrap:
!db/seed.sql
!db/fluentcart-control-plane-seed.sql

# ── WordPress core (never committed) ──────────────────────────────────────────
wp-content/

# ── Theme output/generated files (contain live API tokens) ───────────────────
theme/output-files/

# ── Build & release artifacts ─────────────────────────────────────────────────
output/releases/
*.zip

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/

# ── OS & editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json
